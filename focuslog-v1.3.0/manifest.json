{
  "manifest_version": 3,
  "name": "FocusLog",
  "version": "1.2.0",
  "description": "Track, analyze, and block distracting websites. Active-tab only.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "notifications",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "declarative_net_request": {
    "rule_resources": [{
      "id": "block_rules",
      "enabled": true,
      "path": "block_rules.json"
    }]
  }
}
